<?xml version="1.0"?>
<robot name="differential_drive_robot" 
       xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.02"/>
  <xacro:property name="wheel_mass" value="0.1"/>

  <xacro:property name="bot_mass" value="0.2"/>
  <xacro:property name="bot_chassis_mass" value="0.6"/>

  <xacro:property name="bot_height" value="0.25"/>
  <xacro:property name="bot_length" value="0.15"/>
  <xacro:property name="bot_width" value="0.1"/>

  <!--Inertia Macros-->

  <!--Wheel Inertia-->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(1/12)*m*(3*r*r+h*h)}"
        ixy="0" ixz="0"
        iyy="${(1/12)*m*(3*r*r+h*h)}"
        iyz="0"
        izz="${(1/2)*m*r*r}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="wheel" params="name x_offset y_offset">
    <link name="${name}_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" 
                              r="${wheel_radius}" 
                              h="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="${x_offset} ${y_offset} -0.05" rpy="-1.5707 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>

  <!--Base_Link_Inertia-->
  <xacro:macro name="box_inertia" params="m x y z cz">
    <inertial>
      <origin xyz="0 0 ${cz}" rpy="0 0 0"/>
      <mass value="${m}"/>
      <inertia
        ixx="${(1/12)*m*(y*y+z*z)}"
        ixy="0" ixz="0"
        iyy="${(1/12)*m*(x*x+z*z)}"
        iyz="0"
        izz="${(1/12)*m*(x*x+y*y)}"/>
    </inertial>
  </xacro:macro>

  <!--Base_Link-->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="${bot_length} ${bot_width} ${bot_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="${bot_length} ${bot_width} ${bot_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${bot_chassis_mass}"
                       x="${bot_length}"
                       y="${bot_width}"
                       z="${bot_height}"
                       cz="0.235"/>
  </link>

  <xacro:wheel name="left" x_offset="0" y_offset="${0.06}"/>
  <xacro:wheel name="right" x_offset="0" y_offset="${-0.06}"/>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.03"/>
      </geometry>
      <material name="green">
        <color rgba="0 0.8 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.03"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.1" x="0.05" y="0.05" z="0.03" cz="0"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Front of robot, tilted down 30 degrees -->
    <origin xyz="0.08 0 0.12" rpy="0 -0.523 0"/>
  </joint>

  <!--Gazebo_Plugins-->

  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>1</always_on>
      <update_rate>100</update_rate>
      <topic>/imu</topic>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <topic>/camera/image_raw</topic>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>
  

</robot>

